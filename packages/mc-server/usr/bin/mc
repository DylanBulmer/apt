#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/lib/mc/lib.sh
source /usr/lib/mc/lib.sh

# Load installed command plugins (e.g. mc-rcon adds 'rcon')
for _plugin in /usr/lib/mc/commands.d/*.sh; do
    [[ -f "$_plugin" ]] && source "$_plugin"
done
unset _plugin

_MC_CMD="${1:-help}"
shift || true

case "$_MC_CMD" in
    install) cmd_install  "$@" ;;
    upgrade) cmd_upgrade  "$@" ;;
    start)   cmd_start        ;;
    stop)    cmd_stop         ;;
    restart) cmd_restart      ;;
    status)  cmd_status       ;;
    backup)  cmd_backup       ;;
    restore) cmd_restore  "$@" ;;
    logs)    cmd_logs         ;;
    delete)  cmd_delete       ;;
    help|--help|-h) usage ;;
    *)
        if declare -f "cmd_${_MC_CMD}" >/dev/null 2>&1; then
            "cmd_${_MC_CMD}" "$@"
        else
            error "Unknown command: $_MC_CMD"
            usage
            exit 1
        fi
        ;;
esac
